# Railway Deployment Environment Variables
# Copy these to your Railway service environment variables

# Server
NODE_ENV=production
PORT=3001

# Database (Automatically set by Railway PostgreSQL service)
# DATABASE_URL=postgresql://user:password@host:port/database

# Redis (Automatically set by Railway Redis service)
# REDIS_URL=redis://default:password@host:port

# JWT Secret (Generate a secure random string)
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secure-jwt-secret-key-here-min-32-chars

# YouTube API (Required for livestream monitoring and channel info)
# Get from: https://console.cloud.google.com/
YOUTUBE_API_KEY=your-youtube-api-key-here

# OpenAI (Optional - For AI-powered captions/hashtags)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-key-here

# CORS (Your frontend URL)
CORS_ORIGIN=https://your-frontend-domain.vercel.app

# Notes:
# - DATABASE_URL and REDIS_URL are automatically set by Railway when you add those services
# - Don't manually set DATABASE_URL or REDIS_URL unless using external services
# - Generate a strong JWT_SECRET for production
# - YouTube API key is required for channel monitoring and livestream detection
